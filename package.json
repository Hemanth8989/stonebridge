{
    "name": "stonebridge",
    "private": true,
    "scripts": {
        "dev": "turbo run dev",
        "dev:supplier": "turbo run dev   --filter=@sb/supplier",
        "dev:fabricator": "turbo run dev   --filter=@sb/fabricator",
        "build": "turbo run build",
        "type-check": "turbo run type-check",
        "lint": "turbo run lint",
        "test": "turbo run test",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "clean": "turbo run clean"
    },
    "devDependencies": {
        "turbo": "^2.3.3",
        "typescript": "^5.7.2",
        "@playwright/test": "^1.49.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=9"
    },
    "packageManager": "pnpm@9.15.0"
}